{
  "name": "react-example",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0 --port 3000",
    "build": "vite build",
    "preview": "vite preview --host 0.0.0.0 --port 3000",
    "build:mobile": "npm run build && npx cap sync",
    "sync:android": "npm run build && npx cap sync android",
    "sync:ios": "npm run build && npx cap sync ios",
    "open:android": "npx cap open android",
    "open:ios": "npx cap open ios",
    "doctor": "npx cap doctor",
    "verify:mobile": "node scripts/verify-mobile-readiness.mjs",
    "verify:game-brain": "node scripts/verify-game-brain.mjs",
    "verify:ui-integration": "node scripts/verify-ui-integration.mjs",
    "verify:layout": "node scripts/verify-layout-rules.mjs",
    "verify:persistence": "node scripts/verify-persistence-regression.mjs",
    "verify:session-flow": "node scripts/verify-session-flow.mjs",
    "verify:release-readiness": "node scripts/verify-release-readiness.mjs",
    "verify:release": "node scripts/verify-release.mjs",
    "generate:icons": "npx @capacitor/assets generate",
    "lint": "tsc --noEmit",
    "generate:brand-assets": "node scripts/generate-speedmath-assets.mjs"
  },
  "dependencies": {
    "@capacitor/core": "^8.4.0",
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "jimp": "^1.6.1",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "recharts": "^3.8.1",
    "vite": "^6.2.3"
  },
  "devDependencies": {
    "@capacitor/android": "^8.4.0",
    "@capacitor/assets": "^3.0.5",
    "@capacitor/cli": "^8.4.0",
    "@capacitor/ios": "^8.4.0",
    "@types/node": "^22.14.0",
    "autoprefixer": "^10.4.21",
    "tailwindcss": "^4.1.14",
    "typescript": "~5.8.2",
    "vite": "^6.2.3"
  }
}
