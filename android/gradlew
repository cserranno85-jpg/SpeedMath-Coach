#!/bin/sh

APP_PATH="$0"

while [ -h "$APP_PATH" ]; do
  LS_OUTPUT=$(ls -ld "$APP_PATH")
  LINK_TARGET=$(expr "$LS_OUTPUT" : '.*-> \(.*\)$')
  if expr "$LINK_TARGET" : '/.*' > /dev/null; then
    APP_PATH="$LINK_TARGET"
  else
    APP_PATH="$(dirname "$APP_PATH")/$LINK_TARGET"
  fi
done

APP_HOME=$(cd "$(dirname "$APP_PATH")" >/dev/null 2>&1 && pwd -P)
APP_BASE_NAME=$(basename "$0")
CLASSPATH="$APP_HOME/gradle/wrapper/gradle-wrapper.jar"

if [ -n "$JAVA_HOME" ]; then
  JAVACMD="$JAVA_HOME/bin/java"
else
  JAVACMD="java"
fi

if [ ! -x "$JAVACMD" ] && ! command -v "$JAVACMD" >/dev/null 2>&1; then
  echo "ERROR: Java executable not found. Set JAVA_HOME or add java to PATH."
  exit 1
fi

exec "$JAVACMD" \
  -Dorg.gradle.appname="$APP_BASE_NAME" \
  -classpath "$CLASSPATH" \
  org.gradle.wrapper.GradleWrapperMain \
  "$@"